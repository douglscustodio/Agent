# ============================================================
# .env.example — Jarvis AI Trading Monitor
# Copie para .env e preencha os valores
# No Railway: configure em Settings → Variables
# ============================================================

# ── Banco de dados (Railway PostgreSQL ou Supabase) ──────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Telegram ─────────────────────────────────────────────────
# Obtenha em @BotFather no Telegram
TELEGRAM_BOT_TOKEN=1234567890:AAHxxx...
# Obtenha em @userinfobot no Telegram
TELEGRAM_CHAT_ID=123456789

# ── IA — Groq (gratuito em console.groq.com) ─────────────────
GROQ_API_KEY=gsk_xxxx...

# ── Notícias ─────────────────────────────────────────────────
# Gratuito em cryptopanic.com → Account → API Access
CRYPTOPANIC_TOKEN=xxxx...

# ── Scanner ──────────────────────────────────────────────────
# Símbolos a monitorar (sem USDT, separados por vírgula)
SCAN_SYMBOLS=BTC,ETH,SOL,ARB,OP,AVAX,NEAR,APT,SUI,INJ,TIA,WIF,PEPE,DOGE,LINK,AAVE,FET,RNDR,TAO

# Intervalo dos candles: 1m 3m 5m 15m 30m 1h 4h
SCAN_INTERVAL=15m

# ── Pool de banco ─────────────────────────────────────────────
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_CONNECT_TIMEOUT=10
DB_STARTUP_RETRIES=5

# ── WebSocket ────────────────────────────────────────────────
WS_URL=wss://api.hyperliquid.xyz/ws
WS_HEARTBEAT_INTERVAL=30
WS_RECONNECT_BASE_DELAY=1.0
WS_RECONNECT_MAX_DELAY=60.0

# ── Servidor de saúde ─────────────────────────────────────────
# PORT é definido automaticamente pelo Railway
PORT=8080

# ── App ───────────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO
