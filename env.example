# === Obrigatórias ===
DATABASE_URL=postgresql://user:password@host:5432/dbname

TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=-100123456789

# === Opcionais ===
GROQ_API_KEY=gsk_...                  # IA de análise (llama-3.1-8b-instant)
CRYPTOPANIC_TOKEN=...                  # Feed de notícias crypto

# Scan
SCAN_SYMBOLS=BTC,ETH,SOL              # default: 24 símbolos pré-definidos
SCAN_INTERVAL=15m                      # intervalo dos candles (default: 15m)

# Banco de dados
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_CONNECT_TIMEOUT=10
DB_STARTUP_RETRIES=5
DB_RETRY_BASE_DELAY=2.0

# WebSocket Hyperliquid
WS_URL=wss://api.hyperliquid.xyz/ws
WS_HEARTBEAT_INTERVAL=30
WS_RECONNECT_BASE_DELAY=1.0
WS_RECONNECT_MAX_DELAY=60.0
WS_RECONNECT_MAX_ATTEMPTS=0          # 0 = ilimitado

# App
APP_ENV=production
LOG_LEVEL=INFO
PORT=8080
